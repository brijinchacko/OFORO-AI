# ═══════════════════════════════════════════
# OFORO AI — Production Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local on your server:
#   cp .env.production.example .env.local

# OpenRouter API (same key used by LADX)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Auth JWT Secret — CHANGE THIS to a random 64+ char string
# Generate one with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Site URL — your production domain
NEXT_PUBLIC_SITE_URL=https://oforo.ai

# Microsoft To Do (Azure AD App Registration) — optional
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Node environment
NODE_ENV=production
